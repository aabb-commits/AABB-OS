<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AABB</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500&family=IBM+Plex+Sans+Condensed:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { width: 100%; height: 100%; overflow: hidden; }
    body {
      display: grid;
      grid-template-columns: 1fr 1fr;
      font-family: 'IBM Plex Sans Condensed', sans-serif;
    }

    .panel {
      height: 100vh;
      display: flex; flex-direction: column;
      justify-content: space-between;
      padding: 2rem;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      transition: opacity 0.2s;
    }
    .panel:hover { opacity: 0.85; }

    /* AABB — 검정 배경 */
    .panel-aabb {
      background: #000000;
      color: #ffffff;
      border-right: 1px solid #333;
    }

    /* OS — 흰 배경 */
    .panel-os {
      background: #ffffff;
      color: #000000;
      border-left: 1px solid #000;
    }

    .panel-label {
      font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase;
      opacity: 0.5;
    }

    .panel-title {
      font-size: clamp(3rem, 8vw, 7rem);
      font-weight: 500; letter-spacing: 0.04em;
      text-transform: uppercase; line-height: 1;
      text-align: center;
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 100%;
      pointer-events: none;
    }

    .panel-desc {
      font-size: 0.72rem; letter-spacing: 0.08em;
      line-height: 1.6; opacity: 0.5;
      text-transform: uppercase;
    }

    .panel-arrow {
      font-size: 0.72rem; letter-spacing: 0.1em;
      text-transform: uppercase; opacity: 0.5;
    }

    /* 중앙 세로선 */
    .divider {
      position: fixed; top: 0; left: 50%;
      width: 1px; height: 100%;
      background: #999;
      pointer-events: none; z-index: 10;
    }

    @media (max-width: 600px) {
      body { grid-template-columns: 1fr; grid-template-rows: 1fr 1fr; overflow: auto; }
      html, body { overflow: auto; }
      .panel { height: 50vh; }
      .divider { top: 50%; left: 0; width: 100%; height: 1px; }
    }
  </style>
</head>
<body>

<div class="divider"></div>

<a href="https://aabb.kr" class="panel panel-aabb">
  <div class="panel-label">Design Studio</div>
  <div class="panel-title">AABB</div>
  <div class="panel-desc">
    Brand Identity<br>
    Editorial Design<br>
    Visual Communication
  </div>
</a>

<a href="https://aabb.kr/os" class="panel panel-os">
  <div class="panel-label">Cultural Space &amp; Archive</div>
  <div class="panel-title">OS</div>
  <div class="panel-desc">
    Independent Publications<br>
    Visual Arts<br>
    Seoul, KR
  </div>
</a>

</body>
</html>
